<Window x:Class="WorkFlowDesk.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
        mc:Ignorable="d"
        Title="Iniciar sesión - WorkFlowDesk"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource StitchBackgroundGradientBrush}">
    <Grid MinHeight="480">
        <Ellipse Width="360" Height="360" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-80,-80,0"
                 Fill="#669E00B5" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="280" Height="280" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-60,0,0,-40"
                 Fill="#66FD933D" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>

        <Border Style="{StaticResource GlassCardBorderStyle}"
                MaxWidth="400"
                Margin="32,40"
                Padding="28"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="WorkFlowDesk"
                           Style="{StaticResource StitchH1TextStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Gestión de tareas y proyectos"
                           Style="{StaticResource StitchBodyTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,28"/>

                <TextBlock Text="Nombre de usuario" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Contraseña" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             local:PasswordBoxHelper.Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8"
                             BorderBrush="#D6C0D3"
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,8"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorMessageStyle}"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                <Button Style="{StaticResource StitchPrimaryButtonStyle}"
                        Click="OnLoginClick"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="Iniciar sesión"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource StitchGhostButtonStyle}"
                        Command="{Binding AbrirRegistroCommand}"
                        Content="Crear cuenta"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"/>

                <ProgressBar IsIndeterminate="True"
                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Height="4"
                               Margin="0,16,0,0"
                               Foreground="{StaticResource StitchPrimaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
