<UserControl x:Class="WorkFlowDesk.UI.Views.ClienteFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             xmlns:helpers="clr-namespace:WorkFlowDesk.UI.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="900"
             KeyDown="OnKeyDown">
    <Grid>
        <Border Background="Transparent" MouseLeftButtonUp="OnOverlayClick"/>

        <Border Style="{StaticResource StitchModalGlassPanelStyle}"
                MaxWidth="560"
                Width="560"
                MaxHeight="680"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="16"
                MouseLeftButtonUp="OnModalClick">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource StitchOutlineVariantBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A9E00B5" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Titulo}" Style="{StaticResource StitchH2TextStyle}"/>
                                <TextBlock Text="{Binding Subtitulo}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CancelarCommand}"
                                Width="36" Height="36" Cursor="Hand" ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18" Padding="6">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#33E3DFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,0">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Nombre / contacto" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                <Grid>
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{x:Static helpers:FormTooltips.NombreCliente}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                             Tag="Ej. Elena Martínez"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Empresa" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                <Grid>
                                    <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding Empresa, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{x:Static helpers:FormTooltips.Empresa}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                             Tag="Ej. TechGlobal Solutions"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Email" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <TextBox local:TextBoxBindingHelper.BoundText="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{x:Static helpers:FormTooltips.Email}"
                                                 Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                                 Tag="contacto@empresa.com"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Teléfono" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <TextBox local:TextBoxBindingHelper.BoundText="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                                 Tag="+34 600 000 000"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Dirección" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="4">
                                <TextBox local:TextBoxBindingHelper.BoundText="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{x:Static helpers:FormTooltips.Direccion}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="12,10" FontSize="14" MinHeight="60"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                            </Border>
                        </StackPanel>

                        <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="12,10" Margin="0,0,0,16">
                            <CheckBox Content="Cliente activo" IsChecked="{Binding Activo}"
                                      Foreground="{DynamicResource StitchOnSurfaceBrush}" FontSize="14"/>
                        </Border>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource ErrorMessageStyle}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <Border BorderBrush="{DynamicResource StitchOutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,16" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancelar"
                                        Command="{Binding CancelarCommand}"
                                        Style="{StaticResource StitchModalCancelButtonStyle}"
                                        Margin="0,0,16,0"/>
                                <Button Content="Guardar Cliente"
                                        Command="{Binding GuardarCommand}"
                                        Style="{StaticResource StitchPrimaryButtonStyle}"
                                        Padding="32,10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
