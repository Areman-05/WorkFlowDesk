<UserControl x:Class="WorkFlowDesk.UI.Views.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1100">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24" MaxWidth="1200" HorizontalAlignment="Center">

            <!-- Cabecera -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Reportes" Style="{StaticResource StitchH1TextStyle}"/>
                    <TextBlock Text="Análisis detallado del rendimiento y estado operativo."
                               Style="{StaticResource StitchBodyTextStyle}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource StitchAuthOutlineButtonStyle}"
                            Command="{Binding ExportarResumenCommand}"
                            IsEnabled="{Binding CanExport}"
                            Padding="16,12" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Exportar resumen" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource StitchPrimaryButtonXlStyle}"
                            Command="{Binding CargarReportesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RefreshIcon" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="RefreshIconRotation" Angle="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="Actualizar" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Gráficos -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="7*"/>
                </Grid.ColumnDefinitions>

                <!-- Donut: Estado de Proyectos -->
                <Border Grid.Column="0" Style="{StaticResource GlassCardBorderStyle}" Padding="24" MinHeight="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Estado de Proyectos" Style="{StaticResource StitchH3TextStyle}"/>

                        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Width="220" Height="220">
                                <Grid Width="100" Height="100">
                                    <Ellipse Width="80" Height="80" Stroke="#EFEBFF" StrokeThickness="12"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="80" Height="80" Stroke="#9E00B5" StrokeThickness="12"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             RenderTransformOrigin="0.5,0.5"
                                             Visibility="{Binding MostrarDonut, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             StrokeDashArray="{Binding DonutCompletadosArco, Converter={StaticResource ArcToDashArrayConverter}}">
                                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Ellipse Width="80" Height="80" Stroke="#FD933D" StrokeThickness="12"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             RenderTransformOrigin="0.5,0.5"
                                             Visibility="{Binding MostrarDonut, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             StrokeDashArray="{Binding DonutEnProgresoArco, Converter={StaticResource ArcToDashArrayConverter}}"
                                             StrokeDashOffset="{Binding DonutEnProgresoOffset}">
                                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Ellipse Width="80" Height="80" Stroke="#FFAEDA" StrokeThickness="12"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             RenderTransformOrigin="0.5,0.5"
                                             Visibility="{Binding MostrarDonut, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             StrokeDashArray="{Binding DonutPendientesArco, Converter={StaticResource ArcToDashArrayConverter}}"
                                             StrokeDashOffset="{Binding DonutPendientesOffset}">
                                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                            </Viewbox>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding EficienciaPorcentaje, StringFormat={}{0}%}"
                                           Style="{StaticResource StitchH1TextStyle}"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="TOTAL EFICIENCIA" Style="{StaticResource StitchCaptionTextStyle}"
                                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Grid.Row="2" Columns="3" Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource StitchPrimaryBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="Completados" Style="{StaticResource StitchCaptionTextStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource StitchSecondaryContainerBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="En progreso" Style="{StaticResource StitchCaptionTextStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="#FFAEDA" Margin="0,0,6,0"/>
                                <TextBlock Text="Pendientes" Style="{StaticResource StitchCaptionTextStyle}"/>
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Barras: Productividad -->
                <Border Grid.Column="2" Style="{StaticResource GlassCardBorderStyle}" Padding="24" MinHeight="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Productividad Semanal" Style="{StaticResource StitchH3TextStyle}"/>
                                <TextBlock Text="Tareas finalizadas por periodo" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="7 Días" Command="{Binding Filtrar7DiasCommand}" Padding="12,4" Margin="0,0,4,0"
                                        Cursor="Hand" BorderThickness="0" FontSize="12">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Filtro7DiasActivo}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="30 Días" Command="{Binding Filtrar30DiasCommand}" Padding="12,4"
                                        Cursor="Hand" BorderThickness="0" FontSize="12">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Filtro30DiasActivo}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Height="200" VerticalAlignment="Bottom">
                            <ItemsControl x:Name="ProductividadChart" ItemsSource="{Binding ProductividadVisible}" VerticalAlignment="Bottom">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" VerticalAlignment="Stretch" CornerRadius="6,6,0,0"
                                                    Background="#339E00B5">
                                                <Border x:Name="BarFill" Tag="BarFill" VerticalAlignment="Bottom" CornerRadius="6,6,0,0"
                                                        Height="{Binding AlturaPixelesReporte}"
                                                        Background="{StaticResource StitchPrimaryBrush}"/>
                                            </Border>
                                            <TextBlock Grid.Row="1" Text="{Binding Etiqueta}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Exportar datos -->
            <Border Style="{StaticResource GlassCardBorderStyle}" Padding="32" Margin="0,0,0,24">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="260"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="420"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="12" Background="#1AFD933D" Margin="0,0,24,0">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                       Foreground="{StaticResource StitchSecondaryContainerBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" MaxWidth="400">
                            <TextBlock Text="Exportar datos" Style="{StaticResource StitchH2TextStyle}"/>
                            <TextBlock Text="Descarga los registros en formato CSV para análisis externos o auditorías."
                                       Style="{StaticResource StitchBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                Style="{StaticResource StitchExportPillButtonStyle}"
                                Command="{Binding ExportarEmpleadosCommand}"
                                IsEnabled="{Binding CanExport}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar empleados" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="2" Grid.Column="0"
                                Style="{StaticResource StitchExportPillButtonStyle}"
                                Command="{Binding ExportarProyectosCommand}"
                                IsEnabled="{Binding CanExport}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar proyectos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="2" Grid.Column="2"
                                Style="{StaticResource StitchExportPillButtonStyle}"
                                Command="{Binding ExportarTareasCommand}"
                                IsEnabled="{Binding CanExport}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar tareas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Tarjetas resumen -->
            <UniformGrid Columns="3">
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="0,0,10,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="#1A9E00B5" Margin="0,0,12,0">
                            <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CRECIMIENTO MENSUAL" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CrecimientoMensualTexto}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="5,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="#1AFD933D" Margin="0,0,12,0">
                            <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PROMEDIO ENTREGA" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding PromedioEntregaTexto}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="10,0,0,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="#1AA45E86" Margin="0,0,12,0">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchTertiaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="COLABORACIÓN" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ColaboracionTexto}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <controls:LoadingIndicator Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Margin="0,24,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
