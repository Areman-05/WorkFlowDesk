<Window x:Class="WorkFlowDesk.UI.Views.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorkFlowDesk"
        Width="520"
        Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="OnLoaded">
    <Window.Resources>
        <!-- Post-login -->
        <Storyboard x:Key="GradientShiftStoryboard" RepeatBehavior="Forever">
            <PointAnimation Storyboard.TargetName="AnimatedGradient"
                            Storyboard.TargetProperty="(LinearGradientBrush.StartPoint)"
                            From="0,0" To="1,0.75" Duration="0:0:18" AutoReverse="True">
                <PointAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </PointAnimation.EasingFunction>
            </PointAnimation>
            <PointAnimation Storyboard.TargetName="AnimatedGradient"
                            Storyboard.TargetProperty="(LinearGradientBrush.EndPoint)"
                            From="1,1" To="0.25,0.25" Duration="0:0:18" AutoReverse="True">
                <PointAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </PointAnimation.EasingFunction>
            </PointAnimation>
        </Storyboard>

        <Storyboard x:Key="OrbPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="OrbPrimaryScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.06" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="OrbPrimaryScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.06" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="OrbSecondaryScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.05" Duration="0:0:11" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="OrbSecondaryScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.05" Duration="0:0:11" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="OrbPrimary"
                             Storyboard.TargetProperty="Opacity"
                             From="0.32" To="0.42" Duration="0:0:9"/>
            <DoubleAnimation Storyboard.TargetName="OrbSecondary"
                             Storyboard.TargetProperty="Opacity"
                             From="0.18" To="0.28" Duration="0:0:11" BeginTime="0:0:2"/>
        </Storyboard>

        <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                             Storyboard.TargetProperty="X"
                             From="-100" To="360" Duration="0:0:2.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="LoadingPulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingText"
                             Storyboard.TargetProperty="Opacity"
                             From="0.45" To="0.95" Duration="0:0:1.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Quick splash -->
        <Storyboard x:Key="QuickGradientShiftStoryboard" RepeatBehavior="Forever">
            <PointAnimation Storyboard.TargetName="QuickAnimatedGradient"
                            Storyboard.TargetProperty="(LinearGradientBrush.StartPoint)"
                            From="0,0" To="1,0.6" Duration="0:0:14" AutoReverse="True">
                <PointAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </PointAnimation.EasingFunction>
            </PointAnimation>
            <PointAnimation Storyboard.TargetName="QuickAnimatedGradient"
                            Storyboard.TargetProperty="(LinearGradientBrush.EndPoint)"
                            From="1,1" To="0.3,0.4" Duration="0:0:14" AutoReverse="True">
                <PointAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </PointAnimation.EasingFunction>
            </PointAnimation>
        </Storyboard>

        <Storyboard x:Key="QuickStatusPulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="QuickLoadingText"
                             Storyboard.TargetProperty="Opacity"
                             From="0.55" To="1" Duration="0:0:1.4" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.45" Color="#12000000"/>
        </Border.Effect>

        <Grid x:Name="RootGrid" Opacity="0">
            <!-- ========== POST-LOGIN (larga) ========== -->
            <Grid x:Name="PostLoginPanel">
                <Grid ClipToBounds="True">
                    <Grid.Background>
                        <LinearGradientBrush x:Name="AnimatedGradient" StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2D2A5B" Offset="0"/>
                            <GradientStop Color="#9E00B5" Offset="0.5"/>
                            <GradientStop Color="#D946EF" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Ellipse x:Name="OrbPrimary" Width="420" Height="420"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-80,-80,0,0" Fill="#9E00B5" Opacity="0.36" IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="OrbPrimaryScale" CenterX="210" CenterY="210"/>
                                <TranslateTransform x:Name="OrbPrimaryTranslate"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <BlurEffect Radius="80"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <Ellipse x:Name="OrbSecondary" Width="380" Height="380"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-60,-60" Fill="#7A3800" Opacity="0.22" IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="OrbSecondaryScale" CenterX="190" CenterY="190"/>
                                <TranslateTransform x:Name="OrbSecondaryTranslate"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <BlurEffect Radius="75"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <Ellipse Width="340" Height="340" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Fill="#87466D" Opacity="0.12" IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="OrbTertiaryTranslate"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <BlurEffect Radius="70"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <Grid x:Name="ContentCluster" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0">
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                            <Border Width="92" Height="92" CornerRadius="22" Margin="0,0,0,18" HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#9E00B5" Offset="0"/>
                                        <GradientStop Color="#C028D7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.28" Color="#2E1065"/>
                                </Border.Effect>
                                <TextBlock Text="WFD" FontSize="30" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="WorkFlowDesk" FontSize="32" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Gestión de tareas y proyectos"
                                       FontSize="14" Foreground="#BFFFFFFF"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Grid x:Name="ProgressTrack" Width="280" Height="2">
                            <Border Background="#1FFFFFFF" CornerRadius="1"/>
                            <Border x:Name="ProgressFill" Background="White" CornerRadius="1"
                                    HorizontalAlignment="Left" Width="0" ClipToBounds="True">
                                <Border Width="96" HorizontalAlignment="Left" Opacity="0.75">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                                            <GradientStop Color="#E6FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ShimmerTranslate" X="-100"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <TextBlock x:Name="LoadingText"
                               Text="CARGANDO TU ESPACIO DE TRABAJO..."
                               FontSize="12" Foreground="#99FFFFFF"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="#66FFFFFF" Margin="3"/>
                        <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="#66FFFFFF" Margin="3"/>
                        <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="#66FFFFFF" Margin="3"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ========== QUICK (corta) — misma línea visual que la larga, compacta y opaca ========== -->
            <Grid x:Name="QuickPanel" Visibility="Collapsed">
                <Grid ClipToBounds="True">
                    <Grid.Background>
                        <LinearGradientBrush x:Name="QuickAnimatedGradient" StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2D2A5B" Offset="0"/>
                            <GradientStop Color="#9E00B5" Offset="0.52"/>
                            <GradientStop Color="#6B1578" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                </Grid>

                <Grid x:Name="QuickContentCluster" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="96" Height="96" CornerRadius="22" Margin="0,0,0,20" HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#9E00B5" Offset="0"/>
                                    <GradientStop Color="#C028D7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.32" Color="#2E1065"/>
                            </Border.Effect>
                            <TextBlock Text="WFD" FontSize="32" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="WorkFlowDesk" FontSize="30" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Gestión de tareas y proyectos"
                                   FontSize="13" Foreground="#D9FFFFFF"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>

                        <Grid Width="220" Height="2" Margin="0,28,0,0">
                            <Border Background="#33FFFFFF" CornerRadius="1"/>
                            <Border x:Name="QuickProgressFill" Background="White" CornerRadius="1"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="QuickFooterCluster" VerticalAlignment="Bottom"
                            HorizontalAlignment="Center" Margin="0,0,0,44" Opacity="0">
                    <TextBlock x:Name="QuickLoadingText"
                               Text="Restaurando tu sesión..."
                               FontSize="12" Foreground="#B3FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
