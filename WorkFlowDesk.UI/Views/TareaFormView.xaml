<UserControl x:Class="WorkFlowDesk.UI.Views.TareaFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             xmlns:helpers="clr-namespace:WorkFlowDesk.UI.Helpers"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="900"
             KeyDown="OnKeyDown">
    <UserControl.Resources>
        <Style x:Key="TareaTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource StitchOnSurfaceVariantBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A9E00B5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Background="Transparent" MouseLeftButtonUp="OnOverlayClick"/>

        <Border Style="{StaticResource StitchModalGlassPanelStyle}"
                MaxWidth="680" Width="680" MaxHeight="820"
                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16"
                MouseLeftButtonUp="OnModalClick">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource StitchOutlineVariantBrush}" BorderThickness="0,0,0,1" Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A9E00B5" Margin="0,0,12,0">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Titulo}" Style="{StaticResource StitchH2TextStyle}"/>
                                <TextBlock Text="{Binding Subtitulo}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CancelarCommand}" Width="36" Height="36" Cursor="Hand" ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18" Padding="6">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#33E3DFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12,24,0">
                    <StackPanel>
                        <!-- Pestañas (solo edición) -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,12"
                                      Visibility="{Binding MuestraExtensiones, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="General" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="General">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionGeneral}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Subtareas" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="Subtareas">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionSubtareas}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Dependencias" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="Dependencias">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionDependencias}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Tiempo" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="Tiempo">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionTiempo}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Adjuntos" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="Adjuntos">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionAdjuntos}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Historial" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="Historial">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionHistorial}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Comentarios" Command="{Binding SeleccionarSeccionCommand}" CommandParameter="Comentarios">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TareaTabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSeccionComentarios}" Value="True">
                                                    <Setter Property="Background" Value="#1A9E00B5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource StitchPrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- GENERAL -->
                        <StackPanel Visibility="{Binding EsSeccionGeneral, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Título" Style="{StaticResource StitchLabelTextStyle}" Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding TituloTarea, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}" Tag="Ej. Rediseño del dashboard" Padding="12,10"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Descripción" Style="{StaticResource StitchLabelTextStyle}" Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="4">
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0" Padding="12,10" FontSize="14" MinHeight="60"
                                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                             Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                </Border>
                            </StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Prioridad" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                        <ComboBox ItemsSource="{Binding PrioridadesTarea}" SelectedItem="{Binding Prioridad}"
                                                  Style="{StaticResource StitchModalComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Estado" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                        <ComboBox ItemsSource="{Binding EstadosTarea}" SelectedItem="{Binding Estado}"
                                                  Style="{StaticResource StitchModalComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Fecha límite" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,4"/>
                                <controls:StitchDateField SelectedDate="{Binding FechaVencimiento, Mode=TwoWay}"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Proyecto" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                        <ComboBox ItemsSource="{Binding Proyectos}" SelectedValue="{Binding ProyectoId}"
                                                  SelectedValuePath="Id" DisplayMemberPath="Nombre"
                                                  Style="{StaticResource StitchModalComboBoxStyle}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Asignado a" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                        <ComboBox ItemsSource="{Binding Empleados}" SelectedValue="{Binding AsignadoId}" SelectedValuePath="Id"
                                                  Style="{StaticResource StitchModalComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock><Run Text="{Binding Nombre}"/><Run Text=" "/><Run Text="{Binding Apellidos}"/></TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- SUBTAREAS -->
                        <StackPanel Visibility="{Binding EsSeccionSubtareas, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Subtareas" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Subtareas}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource StitchSurfaceContainerLowBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <CheckBox IsChecked="{Binding Completada, Mode=OneWay}" Content="{Binding Titulo}" VerticalAlignment="Center"
                                                          Command="{Binding DataContext.ToggleSubtareaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding NuevaSubtarea, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}" Tag="Nueva subtarea..." Padding="12,8"/>
                                </Border>
                                <Button Grid.Column="1" Content="Añadir" Command="{Binding AgregarSubtareaCommand}" Margin="8,0,0,0"
                                        Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="14,8"/>
                            </Grid>
                        </StackPanel>

                        <!-- DEPENDENCIAS -->
                        <StackPanel Visibility="{Binding EsSeccionDependencias, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Dependencias" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding DependenciasTexto}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding DependenciasIds}" Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource StitchSurfaceContainerLowBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6">
                                            <TextBlock Text="{Binding StringFormat=Tarea #{0}}" FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <ComboBox ItemsSource="{Binding TareasDisponibles}" SelectedValue="{Binding DependenciaSeleccionadaId}"
                                              SelectedValuePath="Id" DisplayMemberPath="Titulo"
                                              Style="{StaticResource StitchModalComboBoxStyle}"/>
                                </Border>
                                <Button Grid.Column="1" Content="Añadir" Command="{Binding AgregarDependenciaCommand}" Margin="8,0,0,0"
                                        Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="14,8"/>
                            </Grid>
                        </StackPanel>

                        <!-- TIEMPO -->
                        <StackPanel Visibility="{Binding EsSeccionTiempo, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,8">
                                <Run Text="Registro de tiempo — "/>
                                <Run Text="{Binding MinutosTotales}" FontWeight="Bold"/>
                                <Run Text=" min totales"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding RegistrosTiempo}" Margin="0,0,0,12" MaxHeight="180">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource StitchSurfaceContainerLowBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="13">
                                                    <Run Text="{Binding Minutos}"/><Run Text=" min"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Nota}" Style="{StaticResource StitchCaptionTextStyle}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm}" Style="{StaticResource StitchCaptionTextStyle}" Opacity="0.7"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding NuevoMinutos, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}" Tag="Min" Padding="8"/>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding NuevoNotaTiempo, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}" Tag="Nota (opcional)" Padding="8"/>
                                </Border>
                                <Button Grid.Column="3" Content="Registrar" Command="{Binding RegistrarTiempoCommand}" Margin="8,0,0,0"
                                        Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="12,8"/>
                            </Grid>
                        </StackPanel>

                        <!-- ADJUNTOS -->
                        <StackPanel Visibility="{Binding EsSeccionAdjuntos, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Adjuntos" Style="{StaticResource StitchH3TextStyle}" VerticalAlignment="Center"/>
                                <Button Content="Subir archivo" Command="{Binding AgregarAdjuntoCommand}" HorizontalAlignment="Right"
                                        Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="12,6"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Adjuntos}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource StitchSurfaceContainerLowBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding NombreArchivo}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Style="{StaticResource StitchCaptionTextStyle}">
                                                        <Run Text="{Binding TamanoBytes, StringFormat={}{0} bytes}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding FechaSubida, StringFormat=dd/MM/yyyy}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Abrir" Command="{Binding DataContext.AbrirAdjuntoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="10,4" Margin="0,0,6,0"/>
                                                    <Button Content="Eliminar" Command="{Binding DataContext.EliminarAdjuntoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="10,4"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- HISTORIAL -->
                        <StackPanel Visibility="{Binding EsSeccionHistorial, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Historial de actividad" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding HistorialActividad}" MaxHeight="280">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource StitchOutlineVariantBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                            <StackPanel>
                                                <TextBlock FontSize="12" FontWeight="SemiBold">
                                                    <Run Text="{Binding Accion}"/>
                                                    <Run Text=" · " Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                                                    <Run Text="{Binding FechaUtc, StringFormat=dd/MM HH:mm}" Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Detalle}" Style="{StaticResource StitchCaptionTextStyle}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Usuario}" Style="{StaticResource StitchCaptionTextStyle}" Opacity="0.6"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- COMENTARIOS -->
                        <StackPanel Visibility="{Binding EsSeccionComentarios, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Comentarios" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Comentarios}" Margin="0,0,0,8" MaxHeight="200">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource StitchSurfaceContainerLowBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Contenido}" TextWrapping="Wrap" Style="{StaticResource StitchBodyTextStyle}"/>
                                                <TextBlock Margin="0,4,0,0" Style="{StaticResource StitchCaptionTextStyle}">
                                                    <Run Text="{Binding Autor}"/><Run Text=" · "/><Run Text="{Binding FechaCreacion, StringFormat=dd/MM HH:mm}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="4" Margin="0,0,0,8">
                                <TextBox local:TextBoxBindingHelper.BoundText="{Binding NuevoComentario, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0" Padding="10" MinHeight="50"
                                         TextWrapping="Wrap" AcceptsReturn="True" Tag="Escribe un comentario..."/>
                            </Border>
                            <Button Content="Añadir comentario" Command="{Binding AgregarComentarioCommand}"
                                    Style="{StaticResource StitchAuthOutlineButtonStyle}" HorizontalAlignment="Left" Padding="14,8"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" Margin="0,8,0,0"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <Border BorderBrush="{DynamicResource StitchOutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,16" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancelar" Command="{Binding CancelarCommand}" Style="{StaticResource StitchModalCancelButtonStyle}" Margin="0,0,12,0"/>
                                <Button Content="Guardar Tarea" Command="{Binding GuardarCommand}" Style="{StaticResource StitchPrimaryButtonStyle}" Padding="28,10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
