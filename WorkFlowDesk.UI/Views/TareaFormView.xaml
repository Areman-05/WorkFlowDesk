<UserControl x:Class="WorkFlowDesk.UI.Views.TareaFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             xmlns:helpers="clr-namespace:WorkFlowDesk.UI.Helpers"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="900"
             KeyDown="OnKeyDown">
    <Grid>
        <Border Background="Transparent" MouseLeftButtonUp="OnOverlayClick"/>

        <Border Style="{StaticResource StitchModalGlassPanelStyle}"
                MaxWidth="640"
                Width="640"
                MaxHeight="760"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="16"
                MouseLeftButtonUp="OnModalClick">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource StitchOutlineVariantBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A9E00B5" Margin="0,0,12,0">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Titulo}" Style="{StaticResource StitchH2TextStyle}"/>
                                <TextBlock Text="{Binding Subtitulo}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CancelarCommand}"
                                Width="36" Height="36" Cursor="Hand" ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18" Padding="6">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#33E3DFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,0">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Título" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                <Grid>
                                    <TextBlock Text="&#xE163;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding TituloTarea, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{x:Static helpers:FormTooltips.TituloTarea}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                             Tag="Ej. Rediseño del dashboard"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Descripción" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="4">
                                <TextBox local:TextBoxBindingHelper.BoundText="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{x:Static helpers:FormTooltips.DescripcionTarea}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="12,10" FontSize="14" MinHeight="72"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                            </Border>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Prioridad" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <ComboBox ItemsSource="{Binding PrioridadesTarea}"
                                                  SelectedItem="{Binding Prioridad}"
                                                  ToolTip="{x:Static helpers:FormTooltips.Prioridad}"
                                                  Style="{StaticResource StitchModalComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="#66524251" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Estado" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <ComboBox ItemsSource="{Binding EstadosTarea}"
                                                  SelectedItem="{Binding Estado}"
                                                  Style="{StaticResource StitchModalComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="#66524251" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Fecha límite" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <controls:StitchDateField SelectedDate="{Binding FechaVencimiento, Mode=TwoWay}"
                                                      ToolTip="{x:Static helpers:FormTooltips.FechaVencimiento}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Proyecto" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <ComboBox ItemsSource="{Binding Proyectos}"
                                                  SelectedValue="{Binding ProyectoId}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Nombre"
                                                  Style="{StaticResource StitchModalComboBoxStyle}"/>
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="#66524251" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Asignado a" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <ComboBox ItemsSource="{Binding Empleados}"
                                                  SelectedValue="{Binding AsignadoId}"
                                                  SelectedValuePath="Id">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <Run Text="{Binding Nombre}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Apellidos}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox" BasedOn="{StaticResource StitchModalComboBoxStyle}"/>
                                            </ComboBox.Style>
                                        </ComboBox>
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="#66524251" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Visibility="{Binding MuestraComentarios, Converter={StaticResource BooleanToVisibilityConverter}}"
                                BorderBrush="{DynamicResource StitchOutlineVariantBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,16,0,0"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Comentarios" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,12"/>

                                <ItemsControl ItemsSource="{Binding Comentarios}" Margin="0,0,0,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource StitchSurfaceContainerLowBrush}"
                                                    CornerRadius="8"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Contenido}" TextWrapping="Wrap"
                                                               Style="{StaticResource StitchBodyTextStyle}"/>
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource StitchCaptionTextStyle}">
                                                        <Run Text="{Binding Autor}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding FechaCreacion, StringFormat=dd/MM/yyyy HH:mm}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="4" Margin="0,0,0,8">
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding NuevoComentario, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             Padding="12,10" FontSize="14" MinHeight="60"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             Tag="Escribe un comentario..."
                                             Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                </Border>
                                <Button Content="Añadir comentario"
                                        Command="{Binding AgregarComentarioCommand}"
                                        Style="{StaticResource StitchAuthOutlineButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Padding="16,8"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource ErrorMessageStyle}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <Border BorderBrush="{DynamicResource StitchOutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,16" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancelar"
                                        Command="{Binding CancelarCommand}"
                                        Style="{StaticResource StitchModalCancelButtonStyle}"
                                        Margin="0,0,16,0"/>
                                <Button Content="Guardar Tarea"
                                        Command="{Binding GuardarCommand}"
                                        Style="{StaticResource StitchPrimaryButtonStyle}"
                                        Padding="32,10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
