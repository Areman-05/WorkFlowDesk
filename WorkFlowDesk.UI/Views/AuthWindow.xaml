<Window x:Class="WorkFlowDesk.UI.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:WorkFlowDesk.UI.Views"
        mc:Ignorable="d"
        Title="Iniciar sesión - WorkFlowDesk"
        Width="548"
        Height="780"
        MinWidth="360"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource StitchFogBackgroundBrush}">
    <Grid>
        <Ellipse Width="500" Height="500" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-80,-80,0,0" Fill="#1A9E00B5" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="80"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="400" Height="400" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-60,-60" Fill="#1A944A00" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="80"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                 Margin="-120,0,0,0" Fill="#1A87466D" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="80"/>
            </Ellipse.Effect>
        </Ellipse>

        <views:LoginPanel x:Name="LoginPanel"
                          DataContext="{Binding Login}"
                          Visibility="{Binding DataContext.MostrarRegistro, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

        <views:RegisterPanel x:Name="RegisterPanel"
                             DataContext="{Binding Register}"
                             Visibility="{Binding DataContext.MostrarRegistro, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</Window>
