<UserControl x:Class="WorkFlowDesk.UI.Views.EmpleadoFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             xmlns:helpers="clr-namespace:WorkFlowDesk.UI.Helpers"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="900"
             KeyDown="OnKeyDown">
    <!-- Overlay transparente: el fondo se ve con colores normales -->
    <Grid>
        <Border Background="Transparent" MouseLeftButtonUp="OnOverlayClick"/>

        <Border Style="{StaticResource StitchModalGlassPanelStyle}"
                MaxWidth="576"
                Width="576"
                MaxHeight="680"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="16"
                MouseLeftButtonUp="OnModalClick">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabecera modal -->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource StitchOutlineVariantBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A9E00B5" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Titulo}" Style="{StaticResource StitchH2TextStyle}"/>
                                <TextBlock Text="{Binding Subtitulo}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CancelarCommand}"
                                Width="36" Height="36" Cursor="Hand" ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18" Padding="6">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{StaticResource StitchOnSurfaceVariantBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#33E3DFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Cuerpo formulario -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,0">
                    <StackPanel>
                        <!-- Nombre | Apellidos -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nombre" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE7EE;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <TextBox local:TextBoxBindingHelper.BoundText="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{x:Static helpers:FormTooltips.Nombre}"
                                                 Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                                 Tag="Ej. Ana"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Apellidos" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE7EE;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <TextBox local:TextBoxBindingHelper.BoundText="{Binding Apellidos, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{x:Static helpers:FormTooltips.Apellidos}"
                                                 Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                                 Tag="Ej. García"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Email -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Correo electrónico" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                <Grid>
                                    <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                    <TextBox local:TextBoxBindingHelper.BoundText="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{x:Static helpers:FormTooltips.Email}"
                                             Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                             Tag="correo@ejemplo.com"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Teléfono | Departamento -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Teléfono" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <TextBox local:TextBoxBindingHelper.BoundText="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{x:Static helpers:FormTooltips.Telefono}"
                                                 Style="{StaticResource StitchModalInnerTextBoxStyle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Departamento" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <TextBox local:TextBoxBindingHelper.BoundText="{Binding Departamento, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{x:Static helpers:FormTooltips.Departamento}"
                                                 Style="{StaticResource StitchModalInnerTextBoxStyle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Rol | Estado -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Rol del sistema" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Style="{StaticResource StitchModalFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xECAA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                                        <ComboBox ItemsSource="{Binding RolesDisponibles}"
                                                  SelectedItem="{Binding RolSeleccionado}"
                                                  DisplayMemberPath="Nombre"
                                                  Style="{StaticResource StitchModalComboBoxStyle}"/>
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="#66524251" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Estado inicial" Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="40" Margin="4,0,0,0">
                                    <RadioButton Content="Activo" GroupName="EstadoEmpleado"
                                                 IsChecked="{Binding EstadoActivo, Mode=TwoWay}"
                                                 Margin="0,0,24,0" VerticalAlignment="Center">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="{StaticResource StitchOnSurfaceBrush}"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>
                                    <RadioButton Content="Ausente" GroupName="EstadoEmpleado"
                                                 IsChecked="{Binding EstadoAusente, Mode=TwoWay}"
                                                 VerticalAlignment="Center">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="{StaticResource StitchOnSurfaceBrush}"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Fecha contratación -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Fecha de contratación" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <controls:StitchDateField SelectedDate="{Binding FechaContratacion, Mode=TwoWay}"
                                                      ToolTip="{x:Static helpers:FormTooltips.FechaContratacion}"/>
                        </StackPanel>

                        <!-- Avatar -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Avatar" Style="{StaticResource StitchLabelTextStyle}"
                                       Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <controls:AvatarImage AvatarIndex="{Binding SelectedAvatarIndex}"
                                                      FallbackInitials="{Binding InicialesVistaPrevia}"
                                                      Size="40"/>
                                <TextBlock Text="Selecciona un avatar del catálogo"
                                           Style="{StaticResource StitchCaptionTextStyle}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Avatares}"
                                     SelectedValue="{Binding SelectedAvatarIndex, Mode=TwoWay}"
                                     SelectedValuePath="Index"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="6"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="3"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Width="44" Height="44" CornerRadius="22"
                                                            BorderThickness="2" BorderBrush="Transparent" Padding="1">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource StitchPrimaryBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#0D9E00B5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <controls:AvatarImage AvatarIndex="{Binding Index}" Size="36"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource ErrorMessageStyle}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <!-- Footer acciones -->
                        <Border BorderBrush="{StaticResource StitchOutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,16" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancelar"
                                        Command="{Binding CancelarCommand}"
                                        Style="{StaticResource StitchModalCancelButtonStyle}"
                                        Margin="0,0,16,0"/>
                                <Button Content="Guardar Empleado"
                                        Command="{Binding GuardarCommand}"
                                        Style="{StaticResource StitchPrimaryButtonStyle}"
                                        Padding="32,10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
