<UserControl x:Class="WorkFlowDesk.UI.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="1100">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32" MaxWidth="1152" HorizontalAlignment="Center">

            <!-- Cabecera perfil -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Grid Margin="0,0,24,0">
                        <Border Width="96" Height="96" CornerRadius="48"
                                BorderBrush="White" BorderThickness="4">
                            <controls:AvatarImage AvatarIndex="{Binding SelectedAvatarIndex}" Size="88"/>
                        </Border>
                        <Button Width="32" Height="32" Command="{Binding EditarAvatarCommand}"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource StitchPrimaryBrush}" CornerRadius="16">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding NombreCompleto}" Style="{StaticResource StitchH1TextStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding CargoDisplay}" Style="{StaticResource StitchH3TextStyle}"
                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                            <Border Background="{DynamicResource StitchPrimaryTintBrush}" CornerRadius="10" Padding="8,2" Margin="12,0,0,0"
                                    Visibility="{Binding MostrarVerificado, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="VERIFICADO" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource StitchPrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource StitchAuthCancelButtonStyle}"
                            Command="{Binding DescargarReporteCommand}" Padding="20,12" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Descargar Reporte"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource StitchPrimaryButtonStyle}"
                            Command="{Binding GuardarCambiosCommand}" Padding="24,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Guardar Cambios" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Selector avatar -->
            <Border Style="{StaticResource GlassCardBorderStyle}" Padding="24" Margin="0,0,0,24"
                    Visibility="{Binding MostrarSelectorAvatar, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Elige tu avatar" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,16"/>
                    <ListBox ItemsSource="{Binding Avatares}" SelectedValue="{Binding SelectedAvatarIndex, Mode=TwoWay}"
                             SelectedValuePath="Index" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Width="64" Height="64" CornerRadius="32"
                                                    BorderThickness="3" BorderBrush="Transparent" Padding="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource StitchPrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <controls:AvatarImage AvatarIndex="{Binding Index}" Size="52"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" Margin="0,0,0,16"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}" Margin="0,0,0,16"
                       Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- Bento grid -->
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <!-- Información personal -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GlassCardBorderStyle}" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="40" Height="40" CornerRadius="8" Background="{DynamicResource StitchPrimaryTintBrush}" Margin="0,0,12,0">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Información Personal" Style="{StaticResource StitchH2TextStyle}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Nombre completo" Style="{StaticResource StitchCaptionTextStyle}" Margin="4,0,0,6"/>
                                <Border Background="{DynamicResource StitchInputBackgroundBrush}"
                                        BorderBrush="{DynamicResource StitchInputBorderBrush}"
                                        BorderThickness="1" CornerRadius="10" Padding="12,10">
                                    <TextBox Text="{Binding NombreCompleto, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent" FontSize="14"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Correo electrónico" Style="{StaticResource StitchCaptionTextStyle}" Margin="4,0,0,6"/>
                                <Border Background="{DynamicResource StitchInputBackgroundBrush}"
                                        BorderBrush="{DynamicResource StitchInputBorderBrush}"
                                        BorderThickness="1" CornerRadius="10" Padding="12,10">
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent" FontSize="14"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Teléfono" Style="{StaticResource StitchCaptionTextStyle}" Margin="4,0,0,6"/>
                                <Border Background="{DynamicResource StitchInputBackgroundBrush}"
                                        BorderBrush="{DynamicResource StitchInputBorderBrush}"
                                        BorderThickness="1" CornerRadius="10" Padding="12,10">
                                    <TextBox Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent" FontSize="14"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Ubicación" Style="{StaticResource StitchCaptionTextStyle}" Margin="4,0,0,6"/>
                                <controls:CityAutocompleteBox Text="{Binding Ubicacion, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Preferencias -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource GlassCardBorderStyle}" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A944A00" Margin="0,0,12,0">
                                <TextBlock Text="&#xE429;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Preferencias" Style="{StaticResource StitchH2TextStyle}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Idioma" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,0,0,6"/>
                        <Border Background="{DynamicResource StitchInputBackgroundBrush}"
                                BorderBrush="{DynamicResource StitchInputBorderBrush}"
                                BorderThickness="1" CornerRadius="10" Margin="0,0,0,20">
                            <ComboBox ItemsSource="{Binding IdiomasDisponibles}" SelectedItem="{Binding Idioma}"
                                      Style="{StaticResource StitchProfileComboBoxStyle}"
                                      BorderThickness="0" Background="Transparent"/>
                        </Border>

                        <TextBlock Text="Tema de interfaz" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,0,0,8"/>
                        <UniformGrid Columns="2" Margin="0,0,0,20">
                            <Button Command="{Binding SeleccionarTemaCommand}" CommandParameter="Claro" Margin="0,0,6,0"
                                    Cursor="Hand" Padding="12,10" Background="Transparent">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StitchThemeOptionButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemaClaroSeleccionado}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource StitchPrimaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource StitchThemeOptionSelectedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                    <TextBlock Text="Claro" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SeleccionarTemaCommand}" CommandParameter="Oscuro" Margin="6,0,0,0"
                                    Cursor="Hand" Padding="12,10" Background="Transparent">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StitchThemeOptionButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemaOscuroSeleccionado}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource StitchPrimaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource StitchThemeOptionSelectedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                    <TextBlock Text="Oscuro" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Notificaciones de escritorio" FontWeight="SemiBold" FontSize="14"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Alertas de tareas y mensajes" Style="{StaticResource StitchCaptionTextStyle}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding NotificacionesEscritorio}"
                                      Style="{StaticResource StitchToggleSwitchStyle}"
                                      VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Seguridad + Sesiones -->
                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="7*"/>
                    </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassCardBorderStyle}" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1AA45E86" Margin="0,0,12,0">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchTertiaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Seguridad" Style="{StaticResource StitchH2TextStyle}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Command="{Binding CambiarPasswordCommand}" Cursor="Hand" Margin="0,0,0,12"
                                HorizontalAlignment="Stretch" Padding="16,12"
                                Background="{DynamicResource StitchSubtleOverlayBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{DynamicResource StitchSubtleOverlayBrush}"
                                            BorderBrush="{DynamicResource StitchInputBorderBrush}"
                                            BorderThickness="1" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource StitchListHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="&#xE192;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Cambiar contraseña" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding UltimaActualizacionPassword}" Style="{StaticResource StitchCaptionTextStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                            </Grid>
                        </Button>

                        <Border Background="#1AA45E86" BorderBrush="#33A45E86" BorderThickness="1" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                        <TextBlock Text="&#xE877;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   Foreground="{StaticResource StitchTertiaryBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Autenticación de 2 factores" FontWeight="SemiBold" FontSize="14"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0"
                                            CornerRadius="10" Padding="10,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AutenticacionDosFactores}" Value="True">
                                                        <Setter Property="Background" Value="#1A22C55E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding EstadoDosFactoresTexto}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutenticacionDosFactores}" Value="True">
                                                            <Setter Property="Foreground" Value="#15803D"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <CheckBox Grid.Column="2" IsChecked="{Binding AutenticacionDosFactores}"
                                              Style="{StaticResource StitchToggleSwitchStyle}"
                                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="Protege tu cuenta utilizando un código de seguridad enviado a tu dispositivo móvil."
                                           Style="{StaticResource StitchCaptionTextStyle}" TextWrapping="Wrap" Margin="0,0,48,8"/>
                                <Button Command="{Binding ConfigurarMetodosRespaldoCommand}" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Padding="0">
                                    <TextBlock Text="Configurar métodos de respaldo" Foreground="{StaticResource StitchPrimaryBrush}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Sesiones activas -->
                <Border Grid.Column="2" Style="{StaticResource GlassCardBorderStyle}" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#0D181445" Margin="0,0,12,0">
                                <TextBlock Text="&#xE772;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource StitchOnSurfaceBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Sesiones Activas" Style="{StaticResource StitchH2TextStyle}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding SesionesFiltradas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" CornerRadius="8" Margin="0,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource StitchListHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" CornerRadius="20"
                                                        Background="{DynamicResource StitchSurfaceContainerBrush}" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Icono}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Dispositivo}" FontWeight="SemiBold" FontSize="14"/>
                                                        <Border Background="#1A22C55E" CornerRadius="8" Padding="8,2" Margin="8,0,0,0"
                                                                Visibility="{Binding EsActual, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="Actual" FontSize="10" Foreground="#15803D"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Detalle}" Style="{StaticResource StitchCaptionTextStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Content="Finalizar" Command="{Binding DataContext.FinalizarSesionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource StitchErrorBrush}" FontSize="12" FontWeight="SemiBold"
                                                    Visibility="{Binding EsActual, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border BorderBrush="{DynamicResource StitchInputBorderBrush}" BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,16,0,0">
                            <Button Command="{Binding CerrarOtrasSesionesCommand}" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{StaticResource StitchErrorBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Cerrar todas las demás sesiones" Foreground="{StaticResource StitchErrorBrush}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>
                </Border>
                </Grid>
            </Grid>

            <!-- Zona de peligro -->
            <Border Background="#0DBA1A1A" BorderBrush="#33BA1A1A" BorderThickness="1" CornerRadius="12" Padding="24">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Zona de Peligro" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource StitchErrorBrush}"/>
                        <TextBlock Text="Una vez que elimines tu cuenta, no hay vuelta atrás. Por favor, asegúrate."
                                   Style="{StaticResource StitchBodyTextStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Style="{StaticResource StitchDangerButtonStyle}" Command="{Binding DesactivarCuentaCommand}"
                            Content="Desactivar Cuenta" HorizontalAlignment="Right" MinWidth="180" Padding="20,12"/>
                </Grid>
            </Border>

            <controls:LoadingIndicator Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Margin="0,24,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
