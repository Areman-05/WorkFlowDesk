<UserControl x:Class="WorkFlowDesk.UI.Views.FlowStepFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="520"
             KeyDown="OnKeyDown">
    <Grid>
        <Border Background="Transparent" MouseLeftButtonUp="OnOverlayClick"/>

        <Border Style="{StaticResource StitchModalGlassPanelStyle}"
                MaxWidth="520"
                Width="520"
                MaxHeight="560"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="16"
                MouseLeftButtonUp="OnModalClick">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource StitchOutlineVariantBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A9E00B5" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{StaticResource StitchPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Titulo}" Style="{StaticResource StitchH2TextStyle}"/>
                                <TextBlock Text="{Binding Subtitulo}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CancelarCommand}"
                                Width="36" Height="36" Cursor="Hand" ToolTip="Cerrar">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Tipo de paso" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource StitchModalFieldBorderStyle}" Margin="0,0,0,16">
                            <ComboBox ItemsSource="{Binding TiposDisponibles}"
                                      SelectedItem="{Binding TipoSeleccionado}"
                                      DisplayMemberPath="Nombre"
                                      Style="{StaticResource StitchModalComboBoxStyle}"/>
                        </Border>

                        <TextBlock Text="Etiqueta corta" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding EtiquetaAyuda}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource StitchModalFieldBorderStyle}" Margin="0,0,0,16">
                            <TextBox Text="{Binding EtiquetaCorta, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource StitchModalInnerTextBoxStyle}"/>
                        </Border>

                        <TextBlock Text="Descripción" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource StitchModalFieldBorderStyle}" Padding="4" Margin="0,0,0,24">
                            <TextBox Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource StitchModalInnerTextBoxStyle}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="72"/>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding EliminarCommand}"
                                    Visibility="{Binding PuedeEliminar, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Style="{StaticResource StitchAuthCancelButtonStyle}"
                                    Padding="16,10"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="Eliminar paso" FontWeight="SemiBold"/>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding CancelarCommand}"
                                    Style="{StaticResource StitchModalCancelButtonStyle}"
                                    Padding="20,10">
                                <TextBlock Text="Cancelar" FontWeight="SemiBold"/>
                            </Button>

                            <Button Grid.Column="4"
                                    Command="{Binding GuardarCommand}"
                                    Style="{StaticResource StitchPrimaryButtonStyle}"
                                    Padding="20,10">
                                <TextBlock Text="Guardar paso" FontWeight="SemiBold"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
