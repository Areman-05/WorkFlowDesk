<Window x:Class="WorkFlowDesk.UI.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Crear cuenta - WorkFlowDesk"
        Height="620"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Crear cuenta"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Elige tu rol para acceder a las secciones correspondientes."
                       FontSize="12"
                       Foreground="#5D6D7E"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Nombre completo" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NombreCompleto, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Nombre de usuario" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Email" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Contraseña" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

            <TextBlock Text="Confirmar contraseña" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,12"/>

            <TextBlock Text="Rol" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding RolesDisponibles}"
                      SelectedItem="{Binding RolSeleccionado}"
                      DisplayMemberPath="Etiqueta"
                      Margin="0,0,0,12"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorMessageStyle}"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Button Content="Registrarse"
                    Click="OnRegisterClick"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                    Height="35"
                    Margin="0,4,0,0"/>

            <Button Content="Cancelar"
                    Command="{Binding CancelarCommand}"
                    Height="32"
                    Margin="0,8,0,0"/>

            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Height="5"
                         Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
