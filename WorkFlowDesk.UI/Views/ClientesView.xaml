<UserControl x:Class="WorkFlowDesk.UI.Views.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1100">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24" MaxWidth="1200" HorizontalAlignment="Center">

            <!-- Cabecera -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Clientes" Style="{StaticResource StitchH1TextStyle}"/>
                    <TextBlock Text="Gestión de la cartera de clientes y contactos comerciales."
                               Style="{StaticResource StitchBodyTextStyle}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource StitchAuthOutlineButtonStyle}"
                            Command="{Binding ExportarCommand}"
                            Visibility="{Binding CanExport, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Padding="16,10" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Exportar CSV" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource StitchPrimaryButtonStyle}"
                            Command="{Binding CrearClienteCommand}"
                            Visibility="{Binding CanManage, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Nuevo cliente" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Búsqueda -->
            <Border Style="{StaticResource StitchModalFieldBorderStyle}" Margin="0,0,0,20" MaxWidth="480" HorizontalAlignment="Left">
                <Grid>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="#66524251" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                    <TextBox Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             FlowDirection="LeftToRight"
                             Style="{StaticResource StitchModalInnerTextBoxStyle}"
                             Tag="Buscar clientes..."/>
                </Grid>
            </Border>

            <!-- Stats -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="0,0,10,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource StitchPrimaryContainerBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchOnPrimaryContainerBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Clientes" Style="{StaticResource StitchCaptionTextStyle}"/>
                            <TextBlock Text="{Binding TotalClientes}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="5,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource StitchSecondaryContainerBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchOnSecondaryContainerBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Activos" Style="{StaticResource StitchCaptionTextStyle}"/>
                            <TextBlock Text="{Binding Activos}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="5,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource StitchTertiaryContainerBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchOnTertiaryContainerBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Proyectos Activos" Style="{StaticResource StitchCaptionTextStyle}"/>
                            <TextBlock Text="{Binding ProyectosActivos}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassCardBorderStyle}" Margin="10,0,0,0" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource StitchSurfaceContainerBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource StitchPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Crecimiento" Style="{StaticResource StitchCaptionTextStyle}"/>
                            <TextBlock Text="{Binding CrecimientoTexto}" Style="{StaticResource StitchStatNumberStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Tabla -->
            <Border Style="{StaticResource GlassCardBorderStyle}" Padding="0" MinHeight="320" Margin="0,0,0,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource StitchFilterBarBackgroundBrush}"
                            BorderBrush="{DynamicResource StitchRowDividerBrush}" BorderThickness="0,0,0,1" Padding="24,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CLIENTE" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="SECTOR" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="CONTACTO PRINCIPAL" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="ESTADO" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="PROYECTOS" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="ACCIONES" Style="{StaticResource StitchCaptionTextStyle}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Clientes}"
                                  Visibility="{Binding HayElementos, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#0DD6C0D3" BorderThickness="0,0,0,1" Padding="24,16" Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0D9E00B5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0"
                                                    Background="{Binding SectorIconFondo, Converter={StaticResource HexToBrushConverter}}"
                                                    ToolTip="{Binding Sector}">
                                                <TextBlock Text="{Binding SectorIcon}" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                           Foreground="{Binding SectorIconColor, Converter={StaticResource HexToBrushConverter}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NombreDisplay}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                                <TextBlock Text="{Binding CodigoId}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding Sector}" Style="{StaticResource StitchBodyTextStyle}" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ContactoNombre}" Style="{StaticResource StitchBodyTextStyle}"/>
                                            <TextBlock Text="{Binding ContactoEmail}" Style="{StaticResource StitchCaptionTextStyle}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="3" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{Binding EstadoFondo, Converter={StaticResource HexToBrushConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                                         Fill="{Binding EstadoDotColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                <TextBlock Text="{Binding EstadoTexto}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding EstadoTextoColor, Converter={StaticResource HexToBrushConverter}}"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProyectosCount}" FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{DynamicResource StitchOnSurfaceBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ProyectosEtiqueta}" Style="{StaticResource StitchCaptionTextStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.EditarClienteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="32" Height="32" Margin="0,0,4,0" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="6">
                                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                                   Foreground="{StaticResource StitchPrimaryBrush}" HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#1A9E00B5"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Command="{Binding DataContext.EliminarClienteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="32" Height="32" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="6">
                                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                                   Foreground="{StaticResource StitchErrorBrush}" HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#1ABA1A1A"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="1" Visibility="{Binding MostrarEstadoVacio, Converter={StaticResource BooleanToVisibilityConverter}}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="48">
                        <Border Width="96" Height="96" CornerRadius="48"
                                Background="{DynamicResource StitchSurfaceContainerBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                       Foreground="#4D524251" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Sin clientes registrados" Style="{StaticResource StitchH2TextStyle}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Aún no hay clientes en la cartera o ninguno coincide con la búsqueda."
                                   Style="{StaticResource StitchBodyTextStyle}" TextWrapping="Wrap" TextAlignment="Center"
                                   MaxWidth="360" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Button Style="{StaticResource StitchPrimaryButtonStyle}"
                                Command="{Binding CrearClienteCommand}"
                                Visibility="{Binding CanManage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Padding="24,12" HorizontalAlignment="Center">
                            <TextBlock Text="Crear mi primer cliente" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>

                    <controls:LoadingIndicator Grid.Row="1"
                                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Border Grid.Row="2" Background="{DynamicResource StitchFilterBarBackgroundBrush}"
                            BorderBrush="{DynamicResource StitchRowDividerBrush}" BorderThickness="0,1,0,0" Padding="24,14">
                        <TextBlock Text="{Binding InfoPaginacion}" Style="{StaticResource StitchCaptionTextStyle}" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Perspectiva + Acción sugerida -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassCardBorderStyle}" Padding="24" MinHeight="160">
                    <StackPanel>
                        <TextBlock Text="Perspectiva de Negocio" Style="{StaticResource StitchH2TextStyle}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding PerspectivaNegocio}" Style="{StaticResource StitchBodyTextStyle}"
                                   TextWrapping="Wrap" MaxWidth="640" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Cursor="Hand">
                            <Button Command="{Binding VerReporteDetalladoCommand}"
                                    Style="{StaticResource StitchGhostButtonStyle}" Padding="0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Ver reporte detallado" FontWeight="Bold"
                                               Foreground="{StaticResource StitchPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="{StaticResource StitchPrimaryBrush}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource GlassCardBorderStyle}" Padding="24" MinHeight="160">
                    <StackPanel VerticalAlignment="Stretch">
                        <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource StitchPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Acción sugerida" Style="{StaticResource StitchH3TextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding AccionSugerida}" Style="{StaticResource StitchCaptionTextStyle}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <Button Style="{StaticResource StitchAuthOutlineButtonStyle}" Padding="12,8"
                                HorizontalAlignment="Stretch"
                                Command="{Binding PrepararMensajeCommand}">
                            <TextBlock Text="Preparar mensaje" FontWeight="SemiBold"
                                       Foreground="{StaticResource StitchPrimaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
