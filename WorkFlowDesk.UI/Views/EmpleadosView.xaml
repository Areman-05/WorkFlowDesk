<UserControl x:Class="WorkFlowDesk.UI.Views.EmpleadosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Empleados" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>
            <Button Content="Nuevo Empleado" 
                    Command="{Binding CrearEmpleadoCommand}"
                    Visibility="{Binding CanManage, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            <Button Content="Exportar CSV"
                    Command="{Binding ExportarCommand}"
                    Visibility="{Binding CanExport, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            <TextBox Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" 
                     Width="200"
                     Margin="10,0,0,0"
                     Padding="5"/>
        </StackPanel>

        <Grid Grid.Row="1">
        <DataGrid ItemsSource="{Binding Empleados}"
                  Visibility="{Binding HayElementos, Converter={StaticResource BooleanToVisibilityConverter}}"
                  SelectedItem="{Binding EmpleadoSeleccionado}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Departamento" Binding="{Binding Departamento}" Width="*"/>
                <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo}" Width="*"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Editar" 
                                        Command="{Binding DataContext.EditarEmpleadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Margin="5,0"
                                        Padding="10,5"/>
                                <Button Content="Eliminar" 
                                        Command="{Binding DataContext.EliminarEmpleadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Margin="5,0"
                                        Padding="10,5"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <controls:EmptyStateView Title="Sin empleados"
                                 Message="No hay empleados registrados o ninguno coincide con la búsqueda."
                                 Visibility="{Binding MostrarEstadoVacio, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <controls:LoadingIndicator Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding InfoPaginacion}"
                       VerticalAlignment="Center"
                       Foreground="#7F8C8D"
                       Margin="0,0,15,0"/>
            <Button Content="Anterior"
                    Command="{Binding PaginaAnteriorCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0"/>
            <Button Content="Siguiente"
                    Command="{Binding PaginaSiguienteCommand}"
                    Padding="12,6"/>
        </StackPanel>
    </Grid>
</UserControl>
