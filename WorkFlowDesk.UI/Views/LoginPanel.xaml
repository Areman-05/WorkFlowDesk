<UserControl x:Class="WorkFlowDesk.UI.Views.LoginPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="532">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="16,20">
        <StackPanel Width="500">
            <Border Style="{StaticResource GlassCardBorderStyle}" Padding="32">
                <StackPanel>
                    <TextBlock Text="WorkFlowDesk"
                               Style="{StaticResource StitchH1TextStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Gestión de tareas y proyectos"
                               Style="{StaticResource StitchBodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,28"/>

                    <TextBlock Text="Nombre de usuario" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Contraseña" Style="{StaticResource StitchLabelTextStyle}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 local:PasswordBoxHelper.Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8"
                                 BorderBrush="#D6C0D3"
                                 BorderThickness="1"
                                 FontSize="14"
                                 Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorMessageStyle}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <Button Style="{StaticResource StitchPrimaryButtonStyle}"
                            Click="OnLoginClick"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                            <TextBlock Text="Iniciar sesión"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource StitchAuthOutlineButtonStyle}"
                            Command="{Binding AbrirRegistroCommand}"
                            Content="Crear cuenta"
                            Margin="0,12,0,0"/>

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Height="4"
                                 Margin="0,16,0,0"
                                 Foreground="{StaticResource StitchPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Background="#F6F2FF"
                    BorderBrush="#D6C0D3"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{StaticResource StitchOnSurfaceVariantBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Cuentas de prueba:"
                                   Style="{StaticResource StitchCaptionTextStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="admin" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource StitchPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Admin123" FontSize="13"
                                   Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="supervisor" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource StitchPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Supervisor123" FontSize="13"
                                   Foreground="{StaticResource StitchOnSurfaceVariantBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="empleado" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource StitchPrimaryBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Empleado123" FontSize="13"
                                   Foreground="{StaticResource StitchOnSurfaceVariantBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
