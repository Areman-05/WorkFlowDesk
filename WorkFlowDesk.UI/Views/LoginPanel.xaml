<UserControl x:Class="WorkFlowDesk.UI.Views.LoginPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="484">
    <ScrollViewer x:Name="AuthScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="16,20">
        <Grid MinHeight="{Binding ViewportHeight, ElementName=AuthScroll}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420"
                        MinWidth="300"
                        Width="{Binding ViewportWidth, ElementName=AuthScroll, Converter={StaticResource CapWidthConverter}, ConverterParameter=420}">
                <Border Style="{StaticResource StitchAuthGlassCardStyle}">
                    <StackPanel>
                        <!-- Cabecera -->
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="48" Height="48"
                                    CornerRadius="8"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#9E00B5" Offset="0"/>
                                        <GradientStop Color="#C028D7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="#2E1065"/>
                                </Border.Effect>
                                <TextBlock Text="&#xE756;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="WorkFlowDesk"
                                       Style="{StaticResource StitchH1TextStyle}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Gestión de tareas y proyectos"
                                       Style="{StaticResource StitchBodyTextStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Formulario -->
                        <StackPanel Margin="0,32,0,0">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Nombre de usuario"
                                           Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceBrush}"
                                           Margin="4,0,0,4"/>
                                <Border Style="{StaticResource StitchAuthFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE77B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource StitchOutlineVariantBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"
                                                   IsHitTestVisible="False"/>
                                        <TextBox x:Name="NombreUsuarioBox"
                                                 local:TextBoxBindingHelper.BoundText="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource StitchAuthInnerTextBoxStyle}"
                                                 KeyDown="OnLoginFieldKeyDown"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Contraseña"
                                           Style="{StaticResource StitchLabelTextStyle}"
                                           Foreground="{DynamicResource StitchOnSurfaceBrush}"
                                           Margin="4,0,0,4"/>
                                <Border Style="{StaticResource StitchAuthFieldBorderStyle}">
                                    <Grid>
                                        <TextBlock Text="&#xE72E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource StitchOutlineVariantBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"
                                                   IsHitTestVisible="False"/>
                                        <PasswordBox x:Name="PasswordBox"
                                                     Style="{StaticResource StitchAuthInnerPasswordBoxStyle}"
                                                     KeyDown="OnLoginFieldKeyDown"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Style="{StaticResource ErrorMessageStyle}"
                                       Margin="0,16,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                            <StackPanel Margin="0,16,0,0">
                                <Button Style="{StaticResource StitchAuthPrimaryButtonLargeStyle}"
                                        Click="OnLoginClick"
                                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                                        HorizontalAlignment="Stretch"
                                        Content="Iniciar sesión"
                                        Margin="0,0,0,16"/>

                                <Button Style="{StaticResource StitchAuthSecondaryButtonStyle}"
                                        Command="{Binding AbrirRegistroCommand}"
                                        Content="Crear cuenta"/>
                            </StackPanel>

                            <ProgressBar IsIndeterminate="True"
                                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Height="4"
                                         Margin="0,16,0,0"
                                         Foreground="{StaticResource StitchPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Cuentas de prueba (dentro de la tarjeta) -->
                        <Border Style="{StaticResource StitchAuthGlassSubtleStyle}"
                                Margin="0,32,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Opacity="0.8">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Cuentas de prueba:"
                                               Style="{StaticResource StitchCaptionTextStyle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel>
                                    <Border Background="#4DFFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                        <Grid>
                                            <TextBlock Text="admin" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource StitchPrimaryBrush}"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock Text="Admin123" FontSize="12"
                                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                       HorizontalAlignment="Right" Opacity="0.9"/>
                                        </Grid>
                                    </Border>
                                    <Border Background="#4DFFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                        <Grid>
                                            <TextBlock Text="supervisor" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource StitchPrimaryBrush}"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock Text="Supervisor123" FontSize="12"
                                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                       HorizontalAlignment="Right" Opacity="0.9"/>
                                        </Grid>
                                    </Border>
                                    <Border Background="#4DFFFFFF" CornerRadius="4" Padding="8,4">
                                        <Grid>
                                            <TextBlock Text="empleado" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource StitchPrimaryBrush}"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock Text="Empleado123" FontSize="12"
                                                       Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                                       HorizontalAlignment="Right" Opacity="0.9"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock Text="v1.1"
                           Style="{StaticResource StitchCaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,0"
                           Opacity="0.6"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
