<Window x:Class="WorkFlowDesk.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WorkFlowDesk.UI.Controls"
        xmlns:local="clr-namespace:WorkFlowDesk.UI.Behaviors"
        mc:Ignorable="d"
        Title="WorkFlowDesk"
        Height="720"
        Width="1200"
        MinHeight="640"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource StitchBackgroundGradientBrush}"
        Loaded="OnLoaded">
    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigateToEmpleadosCommand}"/>
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigateToProyectosCommand}"/>
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigateToTareasCommand}"/>
        <KeyBinding Key="D5" Modifiers="Control" Command="{Binding NavigateToClientesCommand}"/>
        <KeyBinding Key="D6" Modifiers="Control" Command="{Binding NavigateToReportesCommand}"/>
        <KeyBinding Key="D8" Modifiers="Control" Command="{Binding NavigateToOptimizacionCommand}"/>
        <KeyBinding Key="D7" Modifiers="Control" Command="{Binding NavigateToConfiguracionCommand}"/>
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding LogoutCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <DataTemplate x:Key="NavItemDashboardTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToDashboardCommand}"
                        Visibility="{Binding IsDashboardActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Dashboard" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToDashboardCommand}"
                        Visibility="{Binding IsDashboardActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Dashboard" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemEmpleadosTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToEmpleadosCommand}"
                        Visibility="{Binding IsEmpleadosActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Empleados" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToEmpleadosCommand}"
                        Visibility="{Binding IsEmpleadosActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Empleados" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemProyectosTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToProyectosCommand}"
                        Visibility="{Binding IsProyectosActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Proyectos" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToProyectosCommand}"
                        Visibility="{Binding IsProyectosActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Proyectos" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemTareasTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToTareasCommand}"
                        Visibility="{Binding IsTareasActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Tareas" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToTareasCommand}"
                        Visibility="{Binding IsTareasActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Tareas" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemClientesTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToClientesCommand}"
                        Visibility="{Binding IsClientesActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Clientes" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToClientesCommand}"
                        Visibility="{Binding IsClientesActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Clientes" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemReportesTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToReportesCommand}"
                        Visibility="{Binding IsReportesActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Reportes" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToReportesCommand}"
                        Visibility="{Binding IsReportesActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Reportes" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemOptimizacionTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToOptimizacionCommand}"
                        Visibility="{Binding IsOptimizacionActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Optimización" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToOptimizacionCommand}"
                        Visibility="{Binding IsOptimizacionActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Optimización" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NavItemConfiguracionTemplate">
            <Grid>
                <Button Style="{StaticResource StitchSidebarNavButtonStyle}" Command="{Binding NavigateToConfiguracionCommand}"
                        Visibility="{Binding IsConfiguracionActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Configuración" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}" Command="{Binding NavigateToConfiguracionCommand}"
                        Visibility="{Binding IsConfiguracionActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                        <TextBlock Text="Configuración" Margin="12,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Orbes decorativos -->
        <Ellipse Width="400" Height="400" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-100,0"
                 Fill="#669E00B5" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="100"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="300" Height="300" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="260,0,0,-50"
                 Fill="#66FD933D" IsHitTestVisible="False">
            <Ellipse.Effect>
                <BlurEffect Radius="100"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource StitchSidebarBrush}"
                    BorderBrush="{DynamicResource StitchInputBorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True" Margin="0,24,0,16">
                    <StackPanel DockPanel.Dock="Top" Margin="24,0,24,24">
                        <TextBlock Text="WorkFlowDesk" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding UserRole}" Style="{StaticResource StitchCaptionTextStyle}"
                                   Foreground="#99F3EEFF" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0">
                        <Button Style="{StaticResource StitchSidebarNavButtonStyle}"
                                Command="{Binding NavigateToPerfilCommand}"
                                Visibility="{Binding IsPerfilActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                                <TextBlock Text="Perfil" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StitchSidebarNavActiveButtonStyle}"
                                Command="{Binding NavigateToPerfilCommand}"
                                Visibility="{Binding IsPerfilActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                                <TextBlock Text="Perfil" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StitchSidebarNavButtonStyle}"
                                Command="{Binding LogoutCommand}" Margin="0,8,0,0"
                                ToolTip="Cerrar sesión (Ctrl+L)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets" Width="24"/>
                                <TextBlock Text="Cerrar sesión" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,8">
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemDashboardTemplate}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemEmpleadosTemplate}"
                                        Visibility="{Binding ShowEmpleados, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemProyectosTemplate}"
                                        Visibility="{Binding ShowProyectos, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemTareasTemplate}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemClientesTemplate}"
                                        Visibility="{Binding ShowClientes, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemReportesTemplate}"
                                        Visibility="{Binding ShowReportes, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemOptimizacionTemplate}"
                                        Visibility="{Binding ShowOptimizacion, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NavItemConfiguracionTemplate}"
                                        Visibility="{Binding ShowConfiguracion, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Área principal -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Border Grid.Row="0" Background="{DynamicResource StitchTopBarBackgroundBrush}"
                        BorderBrush="{DynamicResource StitchTopBarBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" VerticalAlignment="Center"
                                Background="{DynamicResource StitchSurfaceContainerBrush}"
                                BorderBrush="{DynamicResource StitchInputBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12,6"
                                Margin="0,0,12,0"
                                Visibility="{Binding IsSearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid MinWidth="260">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Left" IsHitTestVisible="False"/>
                                <TextBox BorderThickness="0" Background="Transparent"
                                         Foreground="{DynamicResource StitchOnSurfaceBrush}"
                                         FlowDirection="LeftToRight"
                                         VerticalAlignment="Center" Padding="28,4,8,4" FontSize="13"
                                         Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                                <TextBlock Text="{Binding SearchPlaceholder}" IsHitTestVisible="False"
                                           Margin="28,0,8,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TextoBusqueda}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsToolbarVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Style="{StaticResource StitchAuthOutlineButtonStyle}"
                                    Command="{Binding ToolbarExportCommand}"
                                    Visibility="{Binding ToolbarExportVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Padding="10,6" Margin="0,0,8,0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Exportar CSV" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource StitchPrimaryButtonStyle}"
                                    Command="{Binding ToolbarCreateCommand}"
                                    Visibility="{Binding ToolbarCreateVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Padding="10,6" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ToolbarCreateLabel}" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="NotificationBellButton"
                                    Command="{Binding ToggleNotificationPanelCommand}"
                                    Width="36" Height="36" Cursor="Hand" Margin="0,0,12,0"
                                    ToolTip="Notificaciones">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <Grid Width="18" Height="18">
                                                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                                       Foreground="{DynamicResource StitchOnSurfaceBrush}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <Ellipse Width="8" Height="8" Fill="#FACC15"
                                                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"
                                                                     Visibility="{Binding DataContext.TieneNotificacionesNoLeidas, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Popup x:Name="NotificationPopup"
                                   PlacementTarget="{Binding ElementName=NotificationBellButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsNotificationPanelOpen, Mode=TwoWay}">
                                <Border Background="{DynamicResource StitchSurfaceBrush}"
                                        BorderBrush="{DynamicResource StitchOutlineVariantBrush}"
                                        BorderThickness="1" CornerRadius="12" Width="340"
                                        MaxHeight="420" Margin="0,8,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.12" Color="#2E0A65"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Padding="16,12"
                                                BorderBrush="{DynamicResource StitchRowDividerBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <TextBlock Text="Notificaciones" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Command="{Binding MarcarNotificacionesLeidasCommand}"
                                                            Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="4,0" Margin="0,0,8,0"
                                                            Visibility="{Binding TieneNotificacionesNoLeidas, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Marcar leídas" FontSize="12"
                                                                   Foreground="{DynamicResource StitchPrimaryBrush}"/>
                                                    </Button>
                                                    <Button Command="{Binding EliminarTodasNotificacionesCommand}"
                                                            Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="4,0"
                                                            Visibility="{Binding HayNotificaciones, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Eliminar todas" FontSize="12"
                                                                   Foreground="{DynamicResource StitchErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="340">
                                            <ItemsControl ItemsSource="{Binding Notificaciones}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0"
                                                                    Command="{Binding DataContext.NavegarDesdeNotificacionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource StitchGhostButtonStyle}"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="14,12" Cursor="Hand">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="32" Height="32" CornerRadius="8"
                                                                            Background="{DynamicResource StitchThemeOptionSelectedBrush}"
                                                                            Margin="0,0,10,0">
                                                                        <TextBlock Text="{Binding IconoGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                                   Foreground="{DynamicResource StitchPrimaryBrush}"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding Titulo}" FontWeight="SemiBold" FontSize="13"
                                                                                   Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                                                                        <TextBlock Text="{Binding Mensaje}" FontSize="12" TextWrapping="Wrap"
                                                                                   Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                                                                        <TextBlock Text="{Binding TiempoRelativo}" FontSize="11"
                                                                                   Foreground="{DynamicResource StitchOnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Button>
                                                            <Button Grid.Column="1"
                                                                    Command="{Binding DataContext.EliminarNotificacionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Eliminar"
                                                                    Width="36" Height="36" Cursor="Hand"
                                                                    VerticalAlignment="Center" Margin="0,0,8,0"
                                                                    Background="Transparent" BorderThickness="0">
                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                           Foreground="{DynamicResource StitchOnSurfaceVariantBrush}"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <TextBlock Grid.Row="1" Text="No hay notificaciones"
                                                   Style="{StaticResource StitchCaptionTextStyle}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16"
                                                   Visibility="{Binding HayNotificaciones, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource StitchOnSurfaceBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding UserRole}" Style="{StaticResource StitchCaptionTextStyle}" HorizontalAlignment="Right"/>
                            </StackPanel>
                            <controls:AvatarImage AvatarIndex="{Binding AvatarIndex}"
                                                  FallbackInitials="{Binding UserInitials}"
                                                  Size="36"
                                                  Cursor="Hand"
                                                  MouseLeftButtonUp="OnAvatarClick"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Contenido -->
                <ContentControl x:Name="ContentArea" Grid.Row="1"/>
            </Grid>
        </Grid>

        <!-- Toast de notificaciones de escritorio -->
        <Border x:Name="DesktopToast"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="24"
                MaxWidth="360"
                Padding="16,14"
                CornerRadius="12"
                Background="{DynamicResource StitchGlassCardBackgroundBrush}"
                BorderBrush="{DynamicResource StitchPrimaryBrush}"
                BorderThickness="1"
                Visibility="Collapsed"
                Opacity="0"
                Panel.ZIndex="100">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18" Color="#2E1065"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ToastTitle" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource StitchOnSurfaceBrush}"/>
                <TextBlock x:Name="ToastMessage" Margin="0,4,0,0" TextWrapping="Wrap"
                           Style="{StaticResource StitchCaptionTextStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
