<Window x:Class="WorkFlowDesk.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkFlowDesk.UI"
        mc:Ignorable="d"
        Title="WorkFlowDesk" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Bottom"
                        Background="#243342"
                        Padding="12"
                        Margin="8,0,8,8">
                    <StackPanel>
                        <TextBlock Text="{Binding UserName}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding UserRole}"
                                   Foreground="#BDC3C7"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,0,0,0">
                <TextBlock Text="WorkFlowDesk" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Margin="15,20,15,30"
                           HorizontalAlignment="Center"/>
                
                <Button Content="Dashboard" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToDashboardCommand}"
                        Margin="10,5"/>
                <Button Content="Empleados" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToEmpleadosCommand}"
                        Visibility="{Binding ShowEmpleados, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="10,5"/>
                <Button Content="Proyectos" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToProyectosCommand}"
                        Visibility="{Binding ShowProyectos, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="10,5"/>
                <Button Content="Tareas" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToTareasCommand}"
                        Margin="10,5"/>
                <Button Content="Clientes" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToClientesCommand}"
                        Visibility="{Binding ShowClientes, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="10,5"/>
                <Button Content="Reportes" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToReportesCommand}"
                        Visibility="{Binding ShowReportes, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="10,5"/>
                <Button Content="Configuración" 
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding NavigateToConfiguracionCommand}"
                        Visibility="{Binding ShowConfiguracion, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="10,5"/>

                <Button Content="Cerrar sesión"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding LogoutCommand}"
                        Margin="10,20,10,10"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="ContentArea"/>
        </Grid>
    </Grid>
</Window>
