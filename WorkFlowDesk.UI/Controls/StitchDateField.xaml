<UserControl x:Class="WorkFlowDesk.UI.Controls.StitchDateField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="40"
             d:DesignWidth="320"
             x:Name="Root">
    <Border Style="{StaticResource StitchModalFieldBorderStyle}">
        <Grid Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="DateTextBox"
                     Grid.Column="0"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="12,0,8,0"
                     FontSize="14"
                     FlowDirection="LeftToRight"
                     Foreground="{DynamicResource StitchOnSurfaceBrush}"
                     VerticalContentAlignment="Center"
                     LostFocus="OnDateTextLostFocus"
                     KeyDown="OnDateTextKeyDown"/>

            <Button x:Name="CalendarButton"
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OnCalendarButtonClick"
                    ToolTip="Abrir calendario">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Width="32" Height="32" Margin="0,0,6,0">
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Foreground="{StaticResource StitchPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A9E00B5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#339E00B5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Popup x:Name="CalendarPopup"
                   PlacementTarget="{Binding ElementName=CalendarButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   HorizontalOffset="-220">
                <Border Background="{DynamicResource StitchSurfaceBrush}"
                        BorderBrush="{DynamicResource StitchOutlineVariantBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="8"
                        Margin="0,6,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#2E1065" Direction="270"/>
                    </Border.Effect>
                    <Calendar x:Name="Calendar"
                              Style="{StaticResource StitchCalendarStyle}"
                              FocusVisualStyle="{x:Null}"
                              SelectedDatesChanged="OnCalendarSelected"
                              BorderThickness="0"/>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
