<UserControl x:Class="WorkFlowDesk.UI.Controls.AvatarImage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="40"
             x:Name="Root"
             HorizontalAlignment="Left"
             VerticalAlignment="Center">
    <Grid Width="{Binding Size, ElementName=Root}"
          Height="{Binding Size, ElementName=Root}">
        <Border x:Name="Placeholder"
                Background="{StaticResource StitchSurfaceContainerBrush}"
                CornerRadius="{Binding CornerRadius, ElementName=Root}">
            <TextBlock x:Name="InitialsText"
                       Text="{Binding FallbackInitials, ElementName=Root}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="{Binding InitialsFontSize, ElementName=Root}"
                       Foreground="{StaticResource StitchPrimaryBrush}"/>
        </Border>
        <Border CornerRadius="{Binding CornerRadius, ElementName=Root}" ClipToBounds="True">
            <Image x:Name="AvatarImg" Stretch="UniformToFill"/>
        </Border>
    </Grid>
</UserControl>
