<UserControl x:Class="WorkFlowDesk.UI.Controls.PasswordRevealBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="320">
    <Grid>
        <PasswordBox x:Name="HiddenBox"
                   Style="{StaticResource StitchAuthInnerPasswordBoxStyle}"
                   Padding="48,14,44,14"
                   PasswordChanged="OnPasswordChanged"/>
        <TextBox x:Name="VisibleBox"
                 Style="{StaticResource StitchAuthInnerTextBoxStyle}"
                 Padding="48,14,44,14"
                 Visibility="Collapsed"
                 TextChanged="OnVisibleTextChanged"/>

        <Button x:Name="ToggleButton"
                Width="36" Height="36"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,6,0"
                Cursor="Hand"
                Click="OnToggleClick"
                ToolTip="Mostrar contraseña"
                Background="Transparent" BorderThickness="0">
            <TextBlock x:Name="ToggleIcon"
                       Text="&#xE7B3;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="16"
                       Foreground="{DynamicResource StitchOutlineVariantBrush}"/>
        </Button>
    </Grid>
</UserControl>
