<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Paleta Stitch oscura suave (lavanda, no negro) -->
    <Color x:Key="StitchPrimaryColor">#C84DDB</Color>
    <Color x:Key="StitchPrimaryContainerColor">#D97AEB</Color>
    <Color x:Key="StitchSecondaryColor">#E8A04A</Color>
    <Color x:Key="StitchSecondaryContainerColor">#FFB86A</Color>
    <Color x:Key="StitchBackgroundColor">#4A4468</Color>
    <Color x:Key="StitchSurfaceColor">#524C72</Color>
    <Color x:Key="StitchSurfaceContainerLowColor">#5C567C</Color>
    <Color x:Key="StitchSurfaceContainerColor">#666086</Color>
    <Color x:Key="StitchOnSurfaceColor">#F8F6FC</Color>
    <Color x:Key="StitchOnSurfaceVariantColor">#D0CAE4</Color>
    <Color x:Key="StitchSidebarColor">#36003E</Color>
    <Color x:Key="StitchOutlineVariantColor">#8E88A8</Color>
    <Color x:Key="StitchErrorColor">#F87171</Color>
    <Color x:Key="StitchSuccessColor">#4ADE80</Color>
    <Color x:Key="StitchTertiaryColor">#C49AB8</Color>
    <Color x:Key="StitchTertiaryContainerColor">#B884A8</Color>
    <Color x:Key="StitchOnTertiaryContainerColor">#FFFBFF</Color>
    <Color x:Key="StitchOnPrimaryContainerColor">#FFFBFF</Color>
    <Color x:Key="StitchOnSecondaryContainerColor">#FFF4E8</Color>

    <SolidColorBrush x:Key="StitchPrimaryBrush" Color="{StaticResource StitchPrimaryColor}"/>
    <SolidColorBrush x:Key="StitchPrimaryContainerBrush" Color="{StaticResource StitchPrimaryContainerColor}"/>
    <SolidColorBrush x:Key="StitchSecondaryBrush" Color="{StaticResource StitchSecondaryColor}"/>
    <SolidColorBrush x:Key="StitchSecondaryContainerBrush" Color="{StaticResource StitchSecondaryContainerColor}"/>
    <SolidColorBrush x:Key="StitchBackgroundBrush" Color="{StaticResource StitchBackgroundColor}"/>
    <SolidColorBrush x:Key="StitchSurfaceBrush" Color="{StaticResource StitchSurfaceColor}"/>
    <SolidColorBrush x:Key="StitchSurfaceContainerBrush" Color="{StaticResource StitchSurfaceContainerColor}"/>
    <SolidColorBrush x:Key="StitchSurfaceContainerLowBrush" Color="{StaticResource StitchSurfaceContainerLowColor}"/>
    <SolidColorBrush x:Key="StitchOnSurfaceBrush" Color="{StaticResource StitchOnSurfaceColor}"/>
    <SolidColorBrush x:Key="StitchOnSurfaceVariantBrush" Color="{StaticResource StitchOnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="StitchSidebarBrush" Color="{StaticResource StitchSidebarColor}"/>
    <SolidColorBrush x:Key="StitchOutlineVariantBrush" Color="{StaticResource StitchOutlineVariantColor}"/>
    <SolidColorBrush x:Key="StitchErrorBrush" Color="{StaticResource StitchErrorColor}"/>
    <SolidColorBrush x:Key="StitchSuccessBrush" Color="{StaticResource StitchSuccessColor}"/>
    <SolidColorBrush x:Key="StitchTertiaryBrush" Color="{StaticResource StitchTertiaryColor}"/>
    <SolidColorBrush x:Key="StitchTertiaryContainerBrush" Color="{StaticResource StitchTertiaryContainerColor}"/>
    <SolidColorBrush x:Key="StitchOnTertiaryContainerBrush" Color="{StaticResource StitchOnTertiaryContainerColor}"/>
    <SolidColorBrush x:Key="StitchOnPrimaryContainerBrush" Color="{StaticResource StitchOnPrimaryContainerColor}"/>
    <SolidColorBrush x:Key="StitchOnSecondaryContainerBrush" Color="{StaticResource StitchOnSecondaryContainerColor}"/>
    <SolidColorBrush x:Key="StitchWhiteBrush" Color="White"/>

    <SolidColorBrush x:Key="StitchInputBackgroundBrush" Color="#666086"/>
    <SolidColorBrush x:Key="StitchInputBorderBrush" Color="#668E88A8"/>
    <SolidColorBrush x:Key="StitchGlassCardBackgroundBrush" Color="#CC666086"/>
    <SolidColorBrush x:Key="StitchGlassCardBorderBrush" Color="#558E88A8"/>
    <SolidColorBrush x:Key="StitchTopBarBackgroundBrush" Color="#E0524C72"/>
    <SolidColorBrush x:Key="StitchTopBarBorderBrush" Color="#338E88A8"/>
    <SolidColorBrush x:Key="StitchSubtleOverlayBrush" Color="#705C567C"/>
    <SolidColorBrush x:Key="StitchListHoverBrush" Color="#805C567C"/>
    <SolidColorBrush x:Key="StitchThemeOptionBackgroundBrush" Color="#405C567C"/>
    <SolidColorBrush x:Key="StitchThemeOptionBorderBrush" Color="#668E88A8"/>
    <SolidColorBrush x:Key="StitchThemeOptionSelectedBrush" Color="#409E00B5"/>
    <SolidColorBrush x:Key="StitchPrimaryTintBrush" Color="#339E00B5"/>
    <SolidColorBrush x:Key="StitchSecondaryButtonBackgroundBrush" Color="#5C567C"/>
    <SolidColorBrush x:Key="StitchSecondaryButtonHoverBrush" Color="#666086"/>
    <SolidColorBrush x:Key="StitchAuthGlassBackgroundBrush" Color="#CC666086"/>
    <SolidColorBrush x:Key="StitchAuthSubtleBackgroundBrush" Color="#405C567C"/>
    <SolidColorBrush x:Key="StitchFilterBarBackgroundBrush" Color="#80666086"/>
    <SolidColorBrush x:Key="StitchRowDividerBrush" Color="#338E88A8"/>
    <SolidColorBrush x:Key="StitchRowHoverBrush" Color="#339E00B5"/>
    <SolidColorBrush x:Key="StitchExportPillBackgroundBrush" Color="#666086"/>
    <SolidColorBrush x:Key="StitchExportPillBorderBrush" Color="#8E88A8"/>
    <SolidColorBrush x:Key="StitchExportPillHoverBackgroundBrush" Color="#5C567C"/>
    <SolidColorBrush x:Key="StitchExportPillHoverBorderBrush" Color="#A8A2BE"/>
    <SolidColorBrush x:Key="StitchRecommendationCardBrush" Color="#CC666086"/>

    <DrawingBrush x:Key="StitchFlowDotGridBrush" TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#668E88A8">
                <GeometryDrawing.Geometry>
                    <EllipseGeometry Center="12,12" RadiusX="1" RadiusY="1"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <LinearGradientBrush x:Key="StitchBackgroundGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#565070" Offset="0"/>
        <GradientStop Color="#4E4870" Offset="0.5"/>
        <GradientStop Color="#4A4468" Offset="1"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="StitchFogBackgroundBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.85" RadiusY="0.85">
        <GradientStop Color="#524C72" Offset="0"/>
        <GradientStop Color="#4A4468" Offset="1"/>
    </RadialGradientBrush>

</ResourceDictionary>
